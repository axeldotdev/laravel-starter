{
    "name": "laravel-zero/laravel-zero",
    "type": "project",
    "description": "This package ghelps you start your Laravel project.",
    "keywords": [
        "axeldotdev",
        "laravel",
        "laravel-starter"
    ],
    "version": "1.0.0",
    "homepage": "https://github.com/axeldotdev/laravel-starter",
    "readme": "https://github.com/axeldotdev/laravel-starter/blob/main/README.md",
    "license": "MIT",
    "authors": [
        {
            "name": "Axel Charpentier",
            "email": "axel.charpentier@hey.com",
            "homepage": "https://github.com/axeldotdev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "laminas/laminas-text": "^2.8",
        "laravel-zero/framework": "^8.8"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.4.3",
        "pestphp/pest": "^1.3",
        "spatie/ray": "^1.28",
        "vimeo/psalm": "^4.8"
    },
    "support": {
        "email": "axel.charpentier@hey.com",
        "source": "https://github.com/axeldotdev/laravel-starter",
        "issues": "https://github.com/axeldotdev/laravel-starter/issues",
        "docs": "https://github.com/axeldotdev/laravel-starter/wiki",
        "chat": "https://github.com/axeldotdev/laravel-starter/discussions"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "psalm": "vendor/bin/psalm",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage-html coverage",
        "format": "vendor/bin/php-cs-fixer fix --allow-risky=yes"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": ["laravel-starter"]
}
